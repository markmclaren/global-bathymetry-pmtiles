        "raster-fade-duration": 0
      }
    },
    {
      "id": "country-boundaries",
      "type": "line",
      "source": "osm-vector",
      "source-layer": "boundary",
      "filter": [
        "all",
        ["==", "admin_level", 2],
        ["!=", "maritime", 1]
      ],
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#313333",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          1,
          0.5,
          5,
          1.2,
          12,
          3
        ],
        "line-opacity": 0.8
      }
    },
    {
      "id": "country-labels",
      "type": "symbol",
      "source": "osm-vector",
      "source-layer": "place",
      "filter": ["==", "class", "country"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          1,
          10,
          4,
          16,
          8,
          22
        ],
        "text-transform": "none",
        "text-letter-spacing": 0.1,
        "visibility": "none",
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#ffffff",
        "text-halo-color": "rgba(0,0,0,0.7)",
